{
	"$schema": "https://esm.sh/wrangler/config-schema.json",
	"name": "fee-payer",
	"compatibility_date": "2025-12-17",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/index.ts",
	"workers_dev": false,
	"ratelimits": [
		{
			"name": "AddressRateLimiter",
			"namespace_id": "888",
			"simple": { "limit": 1000, "period": 60 }
		}
	],
	"preview_urls": true,
	"keep_vars": true,
	"logpush": true,
	"kv_namespaces": [
		{
			"binding": "SponsorApiKeyStore",
			"id": "PLACEHOLDER_KV_NAMESPACE_ID"
		}
	],
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": true,
			"persist": true,
			"destinations": ["internal-logs"]
		},
		"traces": {
			"enabled": true,
			"destinations": ["internal-traces"]
		}
	},
	"env": {
		"privy": {
			"name": "fee-payer-privy",
			"routes": [
				{
					"pattern": "privy-sponsor.testnet.tempo.xyz",
					"zone_name": "tempo.xyz",
					"custom_domain": true
				}
			],
			"workers_dev": false,
			"vars": {
				"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
				"ALLOWED_ORIGINS": "*",
				"TEMPO_ENV": "moderato"
			},
			"ratelimits": [
				{
					"name": "AddressRateLimiter",
					"namespace_id": "888",
					"simple": {
						"limit": 1000,
						"period": 60
					}
				}
			]
		},
		"devnet": {
			"name": "fee-payer-devnet",
			"routes": [
				{
					"pattern": "sponsor.devnet.tempo.xyz",
					"zone_name": "tempo.xyz",
					"custom_domain": true
				}
			],
			"workers_dev": false,
			"vars": {
				"TEMPO_RPC_URL": "https://rpc.devnet.tempoxyz.dev",
				"ALLOWED_ORIGINS": "*",
				"TEMPO_ENV": "devnet"
			},
			"ratelimits": [
				{
					"name": "AddressRateLimiter",
					"namespace_id": "888",
					"simple": {
						"limit": 1000,
						"period": 60
					}
				}
			]
		},
		"moderato": {
			"name": "fee-payer-moderato",
			"routes": [
				{
					"pattern": "sponsor.testnet.tempo.xyz",
					"zone_name": "tempo.xyz",
					"custom_domain": true
				},
				{
					"pattern": "sponsor.moderato.tempo.xyz",
					"zone_name": "tempo.xyz",
					"custom_domain": true
				}
			],
			"workers_dev": false,
			"vars": {
				"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
				"ALLOWED_ORIGINS": "*",
				"TEMPO_ENV": "moderato"
			},
			"ratelimits": [
				{
					"name": "AddressRateLimiter",
					"namespace_id": "888",
					"simple": {
						"limit": 1000,
						"period": 60
					}
				}
			]
		},
		"mainnet": {
			"name": "fee-payer-mainnet",
			"placement": { "mode": "smart" },
			"routes": [
				{
					"pattern": "sponsor.tempo.xyz",
					"zone_name": "tempo.xyz",
					"custom_domain": true
				}
			],
			"workers_dev": false,
			"vars": {
				"ALLOWED_ORIGINS": "*",
				"TEMPO_ENV": "mainnet"
			},
			"kv_namespaces": [
				{
					"binding": "SponsorApiKeyStore",
					"id": "08ce4ce226fe4dd3869ca91d5e3dd700"
				}
			],
			"queues": {
				"producers": [
					{
						"binding": "BILLING_QUEUE",
						"queue": "billing-events"
					}
				]
			},
			"ratelimits": [
				{
					"name": "AddressRateLimiter",
					"namespace_id": "888",
					"simple": {
						"limit": 30,
						"period": 60
					}
				},
				{
					"name": "KeyedAddressRateLimiter",
					"namespace_id": "889",
					"simple": {
						"limit": 1000,
						"period": 60
					}
				}
			]
		}
	}
}
