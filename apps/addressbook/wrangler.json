{
	"$schema": "https://esm.sh/wrangler/config-schema.json",
	"name": "addressbook",
	"compatibility_date": "2025-12-17",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/index.ts",
	"workers_dev": false,
	"preview_urls": true,
	"keep_vars": true,
	"kv_namespaces": [
		{
			"binding": "ADDRESSBOOK",
			"id": "PLACEHOLDER_KV_NAMESPACE_ID"
		}
	],
	"vars": {
		"ALLOWED_ORIGINS": "*"
	},
	"observability": {
		"enabled": true
	}
}
