{
	"$schema": "https://esm.sh/wrangler/config-schema.json",
	"name": "mpp-flow-diagrams",
	"main": "src/index.ts",
	"compatibility_date": "2025-12-17",
	"compatibility_flags": ["nodejs_compat"],
	"keep_vars": true,
	"workers_dev": true,
	"preview_urls": true,
	"assets": {
		"directory": "public",
		"binding": "ASSETS",
		"run_worker_first": true
	},
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": true
		}
	},
	"vars": {
		"MPP_SERVICES_URL": "https://mpp.dev/api/services"
	}
}
